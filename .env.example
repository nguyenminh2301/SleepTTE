# ===========================
# TTE2026_sleep Environment Configuration
# ===========================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO VERSION CONTROL!

# ===========================
# DATA ACCESS CREDENTIALS
# ===========================

# NSRR (National Sleep Research Resource)
# Get your token at: https://sleepdata.org/token
NSRR_TOKEN=your_nsrr_token_here

# NITRC (for OASIS data)
NITRC_USERNAME=your_nitrc_username
NITRC_PASSWORD=your_nitrc_password

# UK Biobank (if applicable)
UKB_APPLICATION_ID=your_application_id
UKB_KEY_FILE=path/to/ukb_key.enc

# ===========================
# PROJECT PATHS
# ===========================

# Data directories
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EXTERNAL_DIR=data/external

# Output directories
OUTPUT_DIR=outputs
MODELS_DIR=outputs/models
FIGURES_DIR=outputs/figures
REPORTS_DIR=outputs/reports

# ===========================
# DATABASE (if applicable)
# ===========================

# Database connection
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=tte2026_sleep
# DB_USER=your_username
# DB_PASSWORD=your_password

# ===========================
# COMPUTE RESOURCES
# ===========================

# Number of CPU cores for parallel processing
N_JOBS=-1

# GPU settings
CUDA_VISIBLE_DEVICES=0

# Random seed for reproducibility
RANDOM_SEED=2026

# ===========================
# API KEYS (if needed)
# ===========================

# OpenAI (for LLM features, if any)
# OPENAI_API_KEY=sk-...

# Weights & Biases (for experiment tracking)
# WANDB_API_KEY=...
# WANDB_PROJECT=tte2026_sleep

# ===========================
# SECURITY
# ===========================

# Secret key for Flask/Streamlit sessions
SECRET_KEY=your_secret_key_here

# Debug mode (set to False in production)
DEBUG=True

# ===========================
# PLATFORM SETTINGS
# ===========================

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Enable/disable features
ENABLE_PATIENT_APP=true
ENABLE_CLINICIAN_DASHBOARD=true
